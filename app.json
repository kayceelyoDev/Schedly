{
  "expo": {
    "name": "schedly",
    "slug": "schedly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-only-white-bg.png",
    "scheme": "schedly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo-only-white-bg.png",
      "bundleIdentifier": "com.kayceelyo.schedly",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo-only-with-out-bg.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kayceelyo.schedly",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/logo-only-with-out-bg.png",
            "imageWidth": 150
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-notifications",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a12d3ec1-84df-47b0-bb26-253dbe702a0e"
      }
    }
  }
}
